      "id": "auth.middleware.session-gate",
      "surface": "auth-access",
      "sourcePatterns": [
        "src/middleware.ts"
      ],
      "event": "A request reaches a protected application path.",
      "outcomes": [
        "Authenticated requests continue to the target path.",
        "Unauthenticated requests redirect to /login and preserve callbackUrl."
      ],
      "outcomeClasses": [
        "success",
        "auth_denied",
        "redirect"
      ],
      "evidence": [
        "redirect",
        "response"
      ],
      "fidelity": "simulated",
      "ownerTests": [
        "src/test/middleware.unit.test.ts"
      ]
    },
