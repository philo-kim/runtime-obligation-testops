        "maxExpandedFiles": 2,
        "maxInventorySources": 1,
        "level": "error"
      }
    },
    {
      "surfaceId": "workflow-orchestration",
      "inventorySourceRule": {
        "maxExpandedFiles": 2,
        "level": "warning"
      },
      "obligationRule": {
        "maxExpandedFiles": 2,
        "maxInventorySources": 1,
        "level": "warning"
      }
    }
  ],
  "inventorySourcePolicies": [],
  "obligationPolicies": []
}
