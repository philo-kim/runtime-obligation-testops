{
  "name": "runtime-obligation-testops",
  "version": "0.1.0",
  "description": "Runtime-obligation-first TestOps control plane for any software project.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rotops": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema",
    "templates",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
