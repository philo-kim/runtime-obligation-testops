{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-obligation.dev/schema/runtime-control-plane.schema.json",
  "title": "Runtime Control Plane",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "principle",
    "evidenceKinds",
    "fidelityLevels",
    "surfaces"
  ],
  "anyOf": [
    {
      "required": ["obligations"]
    },
    {
      "required": ["behaviors"]
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "evidenceKinds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fidelityLevels": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "isolated",
          "simulated",
          "contract",
          "real-dependency",
          "full-system"
        ]
      }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/behavior"
      }
    },
    "behaviors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/behavior"
      }
    }
  },
  "$defs": {
    "executionConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runner": {
          "type": "string",
          "minLength": 1
        },
        "verifyCommand": {
          "type": "string",
          "minLength": 1
        },
        "watchCommand": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "setupFiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testTimeout": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "sourcePatterns",
        "testPatterns"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "sourcePatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sourceIgnorePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testPatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testIgnorePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execution": {
          "$ref": "#/$defs/executionConfig"
        }
      }
    },
    "behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "surface",
        "sourcePatterns",
        "event",
        "outcomes",
        "evidence",
        "fidelity",
        "ownerTests"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9.-]+$"
        },
        "surface": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "sourcePatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inventorySourceIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inventoryBehaviorIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "event": {
          "type": "string",
          "minLength": 1
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "outcomeClasses": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fidelity": {
          "type": "string",
          "enum": [
            "isolated",
            "simulated",
            "contract",
            "real-dependency",
            "full-system"
          ]
        },
        "ownerTests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "implementationStatus": {
          "type": "string",
          "enum": [
            "implemented",
            "partial",
            "missing"
          ]
        }
      }
    }
  }
}
