{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-obligation-testops.dev/schema/runtime-control-plane.schema.json",
  "title": "Runtime Obligation TestOps Control Plane",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "principle",
    "evidenceKinds",
    "fidelityLevels",
    "surfaces",
    "obligations"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "evidenceKinds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "fidelityLevels": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "surfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surface"
      }
    },
    "obligations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/obligation"
      }
    }
  },
  "$defs": {
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runner": {
          "type": "string",
          "minLength": 1
        },
        "verifyCommand": {
          "type": "string",
          "minLength": 1
        },
        "watchCommand": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "setupFiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "include": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testTimeout": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "type": "object"
        }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "sourcePatterns",
        "testPatterns"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "sourcePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "sourceIgnorePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "testPatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "testIgnorePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "execution": {
          "$ref": "#/$defs/execution"
        }
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "surface",
        "sourcePatterns",
        "event",
        "outcomes",
        "evidence",
        "fidelity",
        "ownerTests"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9.-]+$"
        },
        "surface": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$"
        },
        "sourcePatterns": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "event": {
          "type": "string",
          "minLength": 1
        },
        "outcomes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "fidelity": {
          "type": "string",
          "minLength": 1
        },
        "ownerTests": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      }
    }
  }
}
