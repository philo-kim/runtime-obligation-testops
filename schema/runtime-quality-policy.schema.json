{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-obligation-testops.dev/schema/runtime-quality-policy.schema.json",
  "title": "Runtime Quality Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "principle"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "defaultInventorySourceRule": {
      "$ref": "#/$defs/inventorySourceRule"
    },
    "defaultObligationRule": {
      "$ref": "#/$defs/obligationRule"
    },
    "surfacePolicies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/surfacePolicy"
      }
    },
    "inventorySourcePolicies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inventorySourcePolicy"
      }
    },
    "obligationPolicies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/obligationPolicy"
      }
    }
  },
  "$defs": {
    "issueLevel": {
      "type": "string",
      "enum": [
        "error",
        "warning"
      ]
    },
    "inventorySourceRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxExpandedFiles": {
          "type": "integer",
          "minimum": 1
        },
        "level": {
          "$ref": "#/$defs/issueLevel"
        }
      }
    },
    "obligationRule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxExpandedFiles": {
          "type": "integer",
          "minimum": 1
        },
        "maxInventorySources": {
          "type": "integer",
          "minimum": 1
        },
        "level": {
          "$ref": "#/$defs/issueLevel"
        }
      }
    },
    "surfacePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surfaceId"
      ],
      "properties": {
        "surfaceId": {
          "type": "string",
          "minLength": 1
        },
        "inventorySourceRule": {
          "$ref": "#/$defs/inventorySourceRule"
        },
        "obligationRule": {
          "$ref": "#/$defs/obligationRule"
        }
      }
    },
    "inventorySourcePolicy": {
      "allOf": [
        {
          "$ref": "#/$defs/inventorySourceRule"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "inventorySourceId"
          ],
          "properties": {
            "inventorySourceId": {
              "type": "string",
              "minLength": 1
            },
            "maxExpandedFiles": {
              "type": "integer",
              "minimum": 1
            },
            "level": {
              "$ref": "#/$defs/issueLevel"
            }
          }
        }
      ]
    },
    "obligationPolicy": {
      "allOf": [
        {
          "$ref": "#/$defs/obligationRule"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "obligationId"
          ],
          "properties": {
            "obligationId": {
              "type": "string",
              "minLength": 1
            },
            "maxExpandedFiles": {
              "type": "integer",
              "minimum": 1
            },
            "maxInventorySources": {
              "type": "integer",
              "minimum": 1
            },
            "level": {
              "$ref": "#/$defs/issueLevel"
            }
          }
        }
      ]
    }
  }
}
