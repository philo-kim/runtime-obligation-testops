{
  "$id": "https://runtime-obligation-testops.dev/schema/runtime-discovery-policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "version",
    "principle"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "candidateReviewMode": {
      "type": "string",
      "enum": [
        "error",
        "warning",
        "off"
      ]
    },
    "codeFilePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "sourceExtensions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2,
        "pattern": "^\\."
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "scopePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "ignorePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "suppressions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "filePatterns",
          "reason"
        ],
        "properties": {
          "filePatterns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "sourceOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sourceId"
        ],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "includePatterns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "excludePatterns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "mode": {
            "type": "string",
            "enum": [
              "merge",
              "replace"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
