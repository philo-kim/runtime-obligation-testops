{
  "$id": "https://runtime-obligation-testops.dev/schema/runtime-discovery-policy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "version",
    "principle"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "ignorePatterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "suppressions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "filePatterns",
          "reason"
        ],
        "properties": {
          "filePatterns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
