{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runtime-obligation-testops.dev/schema/runtime-inventory.schema.json",
  "title": "Runtime Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "principle",
    "sourceKinds",
    "sources"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "principle": {
      "type": "string",
      "minLength": 1
    },
    "sourceKinds": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "kind",
        "sourcePatterns",
        "events"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9.-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "sourcePatterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expectedEvidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "expectedOutcomeClasses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "surfaceHint": {
          "type": "string",
          "minLength": 1
        },
        "minimumFidelity": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
